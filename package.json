{
  "name": "apex-map-rotation",
  "private": true,
  "version": "0.1.0",
  "homepage": "https://lgaspari.github.io/apex-map-rotation/",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp"
    ]
  },
  "scripts": {
    "build": "vite build",
    "lint": "tsc --noEmit && eslint ./src --ext .tsx,.ts --fix --max-warnings 0",
    "start": "vite",
    "start:production": "vite build && vite preview",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:browser": "TZ=UTC vitest run",
    "test:browser:watch": "TZ=UTC vitest",
    "test:unit": "TZ=UTC vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "TZ=UTC vitest --config vitest.unit.config.ts",
    "test:coverage": "TZ=UTC vitest run --coverage --config vitest.unit.config.ts && TZ=UTC vitest run --coverage --coverage.clean=false",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dayjs": "^1.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/eslint-plugin": "^1.1.7",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.48.1",
    "postcss": "^8.4.35",
    "prettier": "3.2.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8",
    "vitest-browser-react": "^2.2.0",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1"
  }
}
